# ─── App ───────────────────────────────────────────
PORT=3000

# ─── Database ───────────────────────────────────────
DATABASE_URL=postgresql://cornroad:cornroad_secret@localhost:5432/cornroad

# ─── SMTP (example: Gmail App Password) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# ─── Notification ────────────────────────────────────
# Email that receives a notification for each new signup
NOTIFY_EMAIL=your@email.com

# ─── Admin ───────────────────────────────────────────
# Change this to a strong random string (e.g. openssl rand -hex 32)
ADMIN_TOKEN=change_this_token_now

# ─── Optional ────────────────────────────────────────
# Public URL used in admin links inside notification emails
# APP_URL=https://cornroad.com
